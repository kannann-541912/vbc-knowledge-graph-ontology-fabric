{"openapi": "3.0.0", "info": {"title": "Query Refiner", "version": "1.0"}, "paths": {"/refine": {"post": {"operationId": "refineQuery", "description": "Refine a failed SPARQL query and retry.", "requestBody": {"required": true, "content": {"application/json": {"schema": {"type": "object", "properties": {"question": {"type": "string", "description": "The original question"}, "failed_sparql": {"type": "string", "description": "The failed SPARQL"}, "failure_reason": {"type": "string", "description": "Why it failed"}, "attempt_number": {"type": "string", "description": "Attempt number as string"}}, "required": ["question", "failed_sparql", "failure_reason", "attempt_number"]}}}}, "responses": {"200": {"description": "Corrected SPARQL and results", "content": {"application/json": {"schema": {"type": "object"}}}}}}}}}