<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:skos="http://www.w3.org/2004/02/skos/core#"
         xmlns:vbc="https://ontology.vbc.internal/vbc#"
         xml:base="https://ontology.vbc.internal/vbc">

  <owl:Ontology rdf:about="https://ontology.vbc.internal/vbc">
    <rdfs:label>VBC Knowledge Ontology v1.1</rdfs:label>
    <rdfs:comment>Value-Based Care ontology for the AWS Knowledge Fabric Stack</rdfs:comment>
  </owl:Ontology>

  <!-- ═══ Classes ═══ -->
  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#Person">
    <rdfs:label>Person</rdfs:label>
    <rdfs:comment>A human being in the healthcare ecosystem</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#Patient">
    <rdfs:label>Patient</rdfs:label>
    <rdfs:comment>Individual receiving healthcare services</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Person"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#CareTeamMember">
    <rdfs:label>CareTeamMember</rdfs:label>
    <rdfs:comment>Healthcare professional involved in patient care</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Person"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#PatientState">
    <rdfs:label>PatientState</rdfs:label>
    <rdfs:comment>Current clinical or administrative state of a patient</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#PatientStateTransition">
    <rdfs:label>PatientStateTransition</rdfs:label>
    <rdfs:comment>A change from one patient state to another</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#PatientDiagnosis">
    <rdfs:label>PatientDiagnosis</rdfs:label>
    <rdfs:comment>A diagnosis assigned to a specific patient</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#PatientMedication">
    <rdfs:label>PatientMedication</rdfs:label>
    <rdfs:comment>A medication prescribed to a specific patient</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#PatientSymptom">
    <rdfs:label>PatientSymptom</rdfs:label>
    <rdfs:comment>A symptom reported or observed for a patient</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#Physician">
    <rdfs:label>Physician</rdfs:label>
    <rdfs:comment>Licensed medical doctor providing clinical care</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#CareTeamMember"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#PrimaryCarePhysician">
    <rdfs:label>PrimaryCarePhysician</rdfs:label>
    <rdfs:comment>Primary care provider attributed to a patient</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Physician"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#Specialist">
    <rdfs:label>Specialist</rdfs:label>
    <rdfs:comment>Specialist physician in a particular medical domain</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Physician"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#MTMPharmacist">
    <rdfs:label>MTMPharmacist</rdfs:label>
    <rdfs:comment>Pharmacist providing medication therapy management</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#CareTeamMember"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#SocialWorker">
    <rdfs:label>SocialWorker</rdfs:label>
    <rdfs:comment>Social worker providing non-clinical support</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#CareTeamMember"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#BehavioralHealthSpecialist">
    <rdfs:label>BehavioralHealthSpecialist</rdfs:label>
    <rdfs:comment>Specialist in behavioral/mental health</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#CareTeamMember"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#TransitionsNurse">
    <rdfs:label>TransitionsNurse</rdfs:label>
    <rdfs:comment>Nurse managing care transitions</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#CareTeamMember"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#MTMProgram">
    <rdfs:label>MTMProgram</rdfs:label>
    <rdfs:comment>Medication Therapy Management program</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#CareTeamAssignment">
    <rdfs:label>CareTeamAssignment</rdfs:label>
    <rdfs:comment>Assignment of a care team member to a patient</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#CareManager">
    <rdfs:label>CareManager</rdfs:label>
    <rdfs:comment>Care manager coordinating patient care activities</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#CareTeamMember"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#CommunityHealthWorker">
    <rdfs:label>CommunityHealthWorker</rdfs:label>
    <rdfs:comment>Community health worker providing outreach</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#CareTeamMember"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#ClinicalOpsDirector">
    <rdfs:label>ClinicalOpsDirector</rdfs:label>
    <rdfs:comment>Director overseeing clinical operations</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#CareTeamMember"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#Condition">
    <rdfs:label>Condition</rdfs:label>
    <rdfs:comment>A clinical condition or diagnosis</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#ChronicCondition">
    <rdfs:label>ChronicCondition</rdfs:label>
    <rdfs:comment>Long-term persistent medical condition</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Condition"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#AcuteCondition">
    <rdfs:label>AcuteCondition</rdfs:label>
    <rdfs:comment>Short-term medical condition requiring immediate care</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Condition"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#CardiovascularCondition">
    <rdfs:label>CardiovascularCondition</rdfs:label>
    <rdfs:comment>Chronic condition affecting the cardiovascular system</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#ChronicCondition"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#MetabolicCondition">
    <rdfs:label>MetabolicCondition</rdfs:label>
    <rdfs:comment>Chronic condition affecting metabolic function</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#ChronicCondition"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#RespiratoryCondition">
    <rdfs:label>RespiratoryCondition</rdfs:label>
    <rdfs:comment>Chronic condition affecting the respiratory system</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#ChronicCondition"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#RenalCondition">
    <rdfs:label>RenalCondition</rdfs:label>
    <rdfs:comment>Chronic condition affecting kidney function</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#ChronicCondition"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#MentalHealthCondition">
    <rdfs:label>MentalHealthCondition</rdfs:label>
    <rdfs:comment>Chronic behavioral or psychiatric condition</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#ChronicCondition"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#Medication">
    <rdfs:label>Medication</rdfs:label>
    <rdfs:comment>A drug or therapeutic substance</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#HighAlertMedication">
    <rdfs:label>HighAlertMedication</rdfs:label>
    <rdfs:comment>Medication with high risk of harm if misused</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Medication"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#LabTest">
    <rdfs:label>LabTest</rdfs:label>
    <rdfs:comment>A laboratory test ordered for a patient</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#LabResult">
    <rdfs:label>LabResult</rdfs:label>
    <rdfs:comment>Result of a laboratory test</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#NormalLabResult">
    <rdfs:label>NormalLabResult</rdfs:label>
    <rdfs:comment>Lab result within normal reference range</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#LabResult"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#AbnormalLabResult">
    <rdfs:label>AbnormalLabResult</rdfs:label>
    <rdfs:comment>Lab result outside normal reference range</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#LabResult"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#CriticalLabResult">
    <rdfs:label>CriticalLabResult</rdfs:label>
    <rdfs:comment>Lab result requiring immediate clinical action</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#LabResult"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#ImagingResult">
    <rdfs:label>ImagingResult</rdfs:label>
    <rdfs:comment>Result of a diagnostic imaging study</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#Symptom">
    <rdfs:label>Symptom</rdfs:label>
    <rdfs:comment>A clinical symptom reported or observed</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#Allergy">
    <rdfs:label>Allergy</rdfs:label>
    <rdfs:comment>A patient allergy or adverse drug reaction</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#HighRiskState">
    <rdfs:label>HighRiskState</rdfs:label>
    <rdfs:comment>Patient state indicating elevated risk of adverse outcomes</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#PatientState"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#HCCCode">
    <rdfs:label>HCCCode</rdfs:label>
    <rdfs:comment>Hierarchical Condition Category risk adjustment code</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#RiskFactor">
    <rdfs:label>RiskFactor</rdfs:label>
    <rdfs:comment>A factor contributing to a patient's risk score</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#ClinicalRiskFactor">
    <rdfs:label>ClinicalRiskFactor</rdfs:label>
    <rdfs:comment>Clinical factor contributing to risk</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#RiskFactor"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#BehavioralRiskFactor">
    <rdfs:label>BehavioralRiskFactor</rdfs:label>
    <rdfs:comment>Behavioral factor contributing to risk</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#RiskFactor"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#SocialRiskFactor">
    <rdfs:label>SocialRiskFactor</rdfs:label>
    <rdfs:comment>Social determinant factor contributing to risk</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#RiskFactor"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#CareGapOpenState">
    <rdfs:label>CareGapOpenState</rdfs:label>
    <rdfs:comment>State indicating a patient has an open care gap</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#PatientState"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#QualityMeasure">
    <rdfs:label>QualityMeasure</rdfs:label>
    <rdfs:comment>A measure used to evaluate quality of care</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#HEDISMeasure">
    <rdfs:label>HEDISMeasure</rdfs:label>
    <rdfs:comment>HEDIS quality measure from NCQA</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#QualityMeasure"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#CMSStarMeasure">
    <rdfs:label>CMSStarMeasure</rdfs:label>
    <rdfs:comment>CMS Star rating quality measure</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#QualityMeasure"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#CustomMeasure">
    <rdfs:label>CustomMeasure</rdfs:label>
    <rdfs:comment>Custom organization-defined quality measure</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#QualityMeasure"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#CareGap">
    <rdfs:label>CareGap</rdfs:label>
    <rdfs:comment>A gap in recommended preventive or chronic care</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#OpenCareGap">
    <rdfs:label>OpenCareGap</rdfs:label>
    <rdfs:comment>A care gap that has not yet been addressed</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#CareGap"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#ClosedCareGap">
    <rdfs:label>ClosedCareGap</rdfs:label>
    <rdfs:comment>A care gap that has been addressed and closed</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#CareGap"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#ExcludedCareGap">
    <rdfs:label>ExcludedCareGap</rdfs:label>
    <rdfs:comment>A care gap excluded from measurement</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#CareGap"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#InterventionPendingState">
    <rdfs:label>InterventionPendingState</rdfs:label>
    <rdfs:comment>State where an intervention is planned</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#PatientState"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#InterventionActiveState">
    <rdfs:label>InterventionActiveState</rdfs:label>
    <rdfs:comment>State where an intervention is actively underway</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#PatientState"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#CarePlan">
    <rdfs:label>CarePlan</rdfs:label>
    <rdfs:comment>A structured plan for managing a patient's health</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#CareTask">
    <rdfs:label>CareTask</rdfs:label>
    <rdfs:comment>A task within a care plan</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#OutreachTask">
    <rdfs:label>OutreachTask</rdfs:label>
    <rdfs:comment>A care task involving patient outreach</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#CareTask"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#ReferralTask">
    <rdfs:label>ReferralTask</rdfs:label>
    <rdfs:comment>A care task involving specialist referral</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#CareTask"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#FollowUpTask">
    <rdfs:label>FollowUpTask</rdfs:label>
    <rdfs:comment>A care task requiring follow-up with patient</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#CareTask"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#Encounter">
    <rdfs:label>Encounter</rdfs:label>
    <rdfs:comment>A patient-provider interaction</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#InpatientEncounter">
    <rdfs:label>InpatientEncounter</rdfs:label>
    <rdfs:comment>A hospital inpatient admission</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Encounter"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#EDEncounter">
    <rdfs:label>EDEncounter</rdfs:label>
    <rdfs:comment>An emergency department visit</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Encounter"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#OutpatientEncounter">
    <rdfs:label>OutpatientEncounter</rdfs:label>
    <rdfs:comment>An outpatient clinic visit</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Encounter"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#TelehealthEncounter">
    <rdfs:label>TelehealthEncounter</rdfs:label>
    <rdfs:comment>A telehealth or virtual visit</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Encounter"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#SNFEncounter">
    <rdfs:label>SNFEncounter</rdfs:label>
    <rdfs:comment>A skilled nursing facility stay</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Encounter"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#UtilizationRiskFactor">
    <rdfs:label>UtilizationRiskFactor</rdfs:label>
    <rdfs:comment>Risk factor related to healthcare utilization patterns</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#RiskFactor"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#Claim">
    <rdfs:label>Claim</rdfs:label>
    <rdfs:comment>A healthcare insurance claim</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#SDOHBarrier">
    <rdfs:label>SDOHBarrier</rdfs:label>
    <rdfs:comment>A social determinant of health barrier</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#FoodInsecurityBarrier">
    <rdfs:label>FoodInsecurityBarrier</rdfs:label>
    <rdfs:comment>SDOH barrier related to food insecurity</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#SDOHBarrier"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#HousingInstabilityBarrier">
    <rdfs:label>HousingInstabilityBarrier</rdfs:label>
    <rdfs:comment>SDOH barrier related to housing instability</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#SDOHBarrier"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#TransportationBarrier">
    <rdfs:label>TransportationBarrier</rdfs:label>
    <rdfs:comment>SDOH barrier related to lack of transportation</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#SDOHBarrier"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#SocialIsolationBarrier">
    <rdfs:label>SocialIsolationBarrier</rdfs:label>
    <rdfs:comment>SDOH barrier related to social isolation</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#SDOHBarrier"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#SDOHAssessment">
    <rdfs:label>SDOHAssessment</rdfs:label>
    <rdfs:comment>A social needs assessment for a patient</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#SocialCareCoordinationProgram">
    <rdfs:label>SocialCareCoordinationProgram</rdfs:label>
    <rdfs:comment>Program coordinating social care services</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#FinancialHardshipBarrier">
    <rdfs:label>FinancialHardshipBarrier</rdfs:label>
    <rdfs:comment>SDOH barrier related to financial hardship</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#SDOHBarrier"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#VBCContract">
    <rdfs:label>VBCContract</rdfs:label>
    <rdfs:comment>A value-based care contract between payer and provider</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#Organization">
    <rdfs:label>Organization</rdfs:label>
    <rdfs:comment>A healthcare organization</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#HealthSystem">
    <rdfs:label>HealthSystem</rdfs:label>
    <rdfs:comment>A large integrated health system</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Organization"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#ACO">
    <rdfs:label>ACO</rdfs:label>
    <rdfs:comment>Accountable Care Organization</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Organization"/>
  </owl:Class>

  <owl:Class rdf:about="https://ontology.vbc.internal/vbc#MedicalGroup">
    <rdfs:label>MedicalGroup</rdfs:label>
    <rdfs:comment>A group medical practice</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://ontology.vbc.internal/vbc#Organization"/>
