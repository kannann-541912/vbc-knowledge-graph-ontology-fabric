  <!-- ═══ Object Properties ═══ -->
  <owl:ObjectProperty rdf:about="https://ontology.vbc.internal/vbc#hasDiagnosis">
    <rdfs:domain rdf:resource="https://ontology.vbc.internal/vbc#Patient"/>
    <rdfs:range  rdf:resource="https://ontology.vbc.internal/vbc#PatientDiagnosis"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="https://ontology.vbc.internal/vbc#hasCareTeamAssignment">
    <rdfs:domain rdf:resource="https://ontology.vbc.internal/vbc#Patient"/>
    <rdfs:range  rdf:resource="https://ontology.vbc.internal/vbc#CareTeamAssignment"/>
  </owl:ObjectProperty>
  <owl:FunctionalProperty rdf:about="https://ontology.vbc.internal/vbc#hasPCP">
    <rdfs:domain rdf:resource="https://ontology.vbc.internal/vbc#Patient"/>
